{
  "name": "football-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd frontend && pnpm dev",
    "dev:api": "cd backend && uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload --reload-dir api",
    "build": "cd frontend && pnpm install && pnpm build",
    "test:e2e": "pnpm exec playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0"
  },
  "packageManager": "pnpm@10.4.1"
}
