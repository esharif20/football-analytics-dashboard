# Football Analytics Dashboard - Environment Configuration
# Copy this file to .env and fill in values as needed

# Required for local development
LOCAL_DEV_MODE=true
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/football_dashboard
LOCAL_STORAGE_DIR=./uploads
OWNER_OPEN_ID=local-dev-user

# AI Commentary — at least one key required for tactical analysis and chat features
#
# LLM provider selection: "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# Google Gemini API key (recommended — free tier available)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API key (alternative provider, supports native streaming)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the default model for the selected provider
# Gemini default: gemini-2.5-flash  |  OpenAI default: gpt-4o-mini
LLM_MODEL=

# Optional: Roboflow API key for pitch detection
# Get one at: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=

# RunPod SSH config — used by scripts/pipeline-e2e.sh and scripts/sync-to-pod.sh
RUNPOD_SSH_HOST=ssh.runpod.io
RUNPOD_SSH_PORT=22
RUNPOD_SSH_KEY=~/.ssh/id_ed25519
RUNPOD_SSH_USER=your-pod-user@your-pod-id
RUNPOD_WORKER_DIR=/workspace/pipeline
