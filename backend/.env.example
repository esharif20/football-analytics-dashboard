# Football Analytics Dashboard — Backend Environment Variables
# Copy to backend/.env and fill in values

# --- Database ---
# MySQL connection string (Phase 5 will migrate to PostgreSQL/Supabase)
DATABASE_URL=mysql+aiomysql://root:password@localhost:3307/football_analytics

# --- Authentication ---
# JWT signing secret — MUST change in production
JWT_SECRET=dev-secret-change-in-production

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Development Mode ---
# Set to "true" to enable auto-login middleware (dev only)
LOCAL_DEV_MODE=true
OWNER_OPEN_ID=local-dev-user

# --- Local Storage ---
LOCAL_STORAGE_DIR=./uploads

# --- Worker API ---
WORKER_API_KEY=

# --- ML Model URLs ---
# Download URLs for YOLO model weights (required for pipeline worker)
# These must point to .pt files accessible via HTTP GET
MODEL_URL_PLAYER=
MODEL_URL_BALL=
MODEL_URL_PITCH=

# --- Worker Configuration ---
# URL the worker polls for pending analyses
DASHBOARD_URL=http://localhost:8000
POLL_INTERVAL=5
COMPLETE_RETRIES=3

# --- LLM Tactical Commentary ---
# Provider: "gemini" or "openai"
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=
